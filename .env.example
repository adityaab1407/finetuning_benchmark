# ──────────────────────────────────────────────────────────────────────
# Financial Fine-Tuning Laboratory — Environment Variables
# Copy this file to .env and fill in your keys.
# ──────────────────────────────────────────────────────────────────────

# GROQ API — get from console.groq.com/keys
GROQ_API_KEY=

# MODEL ASSIGNMENTS — override defaults if Groq model IDs change
# MODEL_ZERO_SHOT=meta-llama/llama-4-scout-17b-16e-instruct
# MODEL_FEW_SHOT=meta-llama/llama-4-scout-17b-16e-instruct
# MODEL_COT=meta-llama/llama-4-scout-17b-16e-instruct
# MODEL_RAG=meta-llama/llama-4-scout-17b-16e-instruct
# MODEL_JUDGE=llama-3.1-8b-instant
# MODEL_TEACHER=llama-3.3-70b-versatile
# MODEL_SCORER=llama-3.1-8b-instant
# MODEL_FALLBACK=moonshotai/kimi-k2-instruct

# RATE LIMITING — tune if you hit Groq free-tier limits
# GROQ_CALL_DELAY_SECONDS=2.5
# GROQ_MAX_RETRIES=3
# GROQ_RPD_SOFT_LIMIT=800
# BENCHMARK_THREADS=4

# HUGGING FACE — get from huggingface.co/settings/tokens (needed for gated models)
HF_TOKEN=
# HuggingFace username (for dataset push)
HF_USERNAME=

# WEIGHTS & BIASES — get from wandb.ai/authorize
WANDB_API_KEY=
# WANDB_PROJECT=financial-finetuning

# TRAINING — override defaults for QLoRA hyperparameters
# BASE_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3
# LORA_RANK=16
# LORA_ALPHA=32
# LORA_DROPOUT=0.05
# MAX_SEQ_LENGTH=2048
# TRAINING_EPOCHS=3
# LEARNING_RATE=0.0002
# PER_DEVICE_BATCH_SIZE=1
# GRADIENT_ACCUMULATION_STEPS=8

# SERVING — Ollama local inference server
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL_NAME=mistral-financial
# FASTAPI_HOST=0.0.0.0
# FASTAPI_PORT=8000

# LANGFUSE — get from cloud.langfuse.com project settings
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
